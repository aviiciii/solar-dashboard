# Copy this file to .env and fill in real values. .env is gitignored - never commit it.

# JWT from the Polycab portal: log in at pv.polycabmonitoring.com, open DevTools ->
# Application -> Local Storage -> token (or the `authorization` header on any XHR request).
# It's long-lived (~360 days observed), so this only needs to be re-extracted if it
# ever gets invalidated - not on every run.
POLYCAB_TOKEN=

# Your inverter's serial number, e.g. "2620-119401326P" (found via the AllInverterList /
# InverterDetail responses, or in the portal's device list).
GOODS_ID=

# Your Polycab account id, e.g. "1137916" (found in the GetMemberData / getAllAllMember
# response, or in the JWT's `data.MemberAutoID` field if populated for your account).
MEMBER_AUTO_ID=

# Optional: earliest date to backfill history from on the very first run, format YYYY-MM-DD.
# If unset, the first run will only backfill from today onward (no pre-existing history).
# Set this to your plant's install/setup date to pull in everything the portal still has.
BACKFILL_START_DATE=

# Optional overrides (sensible defaults if unset):
# DB_PATH=data/readings.db
# LOG_PATH=data/collector.log
# STATE_PATH=data/collector_state.json
# STALE_MINUTES=20
# MAX_BACKFILL_DAYS_PER_RUN=60
